    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@subql/types": "^3.0.0"
  },
  "devDependencies": {
    "@subql/cli": "^4.0.0",
    "@subql/testing": "^2.0.0",
    "typescript": "^5.0.0",
    "jest": "^29"
  }
}
